age_sex_data <- arrests |>
filter(!is.na(age), !is.na(sex)) |>
filter(sex %in% c("F", "M")) |>
mutate(
sex = recode(sex,
"F" = "Female",
"M" = "Male")
)
ggplot(age_sex_data,
aes(x = sex,
y = age,
fill = sex)) +
geom_boxplot(
alpha = 0.85,
outlier.alpha = 0.25
) +
scale_fill_manual(
values = c(
"Female" = "#6F4E9C",
"Male" = "#5DADE2"
)
) +
labs(
title = "Age Distribution of Arrests by Sex",
x = "Sex",
y = "Age",
caption = "Source: Massachusetts arrests data"
) +
theme_minimal() +
theme(
legend.position = "none",
panel.grid = element_blank(),
plot.caption = element_text(size = 7, hjust = 1)
)
