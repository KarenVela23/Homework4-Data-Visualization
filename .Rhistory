covid_top20 <- covid |>
group_by(Entity) |>
summarize(
avg_daily_cases = mean(daily_cases_mean, na.rm = TRUE),
avg_daily_deaths = mean(daily_deaths_mean, na.rm = TRUE)
) |>
filter(avg_daily_cases > 0, avg_daily_deaths > 0) |>
slice_max(avg_daily_cases, n = 20)
ggplot(covid_top20,
aes(x = avg_daily_cases,
y = avg_daily_deaths,
label = Entity)) +
geom_point(
color = "#4F6F8F",
size = 3,
alpha = 0.8
) +
geom_text(
vjust = -0.7,
size = 3,
check_overlap = TRUE
) +
labs(
title = "Average Daily COVID-19 Cases and Deaths among Top 20 Countries",
x = "Average Daily Cases",
y = "Average Daily Deaths",
caption = "Source: COVID-19 daily country data"
) +
theme_minimal() +
theme(
panel.grid.minor = element_blank(),
plot.caption = element_text(size = 7, hjust = 1)
)
covid_year_data <- covid |>
group_by(year) |>
summarize(
avg_daily_cases = mean(daily_cases_mean, na.rm = TRUE),
avg_daily_deaths = mean(daily_deaths_mean, na.rm = TRUE)
) |>
filter(!is.na(year),
avg_daily_cases > 0,
avg_daily_deaths > 0)
ggplot(covid_year_data,
aes(x = avg_daily_cases,
y = avg_daily_deaths,
label = year)) +
geom_point(
color = "#4F6F8F",
size = 4,
alpha = 0.85
) +
geom_text(
vjust = -0.8,
size = 3.5
) +
labs(
title = "Average Daily COVID-19 Cases and Deaths by Year",
x = "Average Daily Cases",
y = "Average Daily Deaths",
caption = "Source: COVID-19 daily country data"
) +
theme_minimal() +
theme(
panel.grid = element_blank(),
plot.caption = element_text(size = 7, hjust = 1)
)
covid_year_data <- covid |>
group_by(year) |>
summarize(
avg_daily_cases = mean(daily_cases_mean, na.rm = TRUE),
