age_sex_data <- arrests |>
filter(!is.na(age), !is.na(sex)) |>
filter(sex %in% c("F", "M")) |>
mutate(
sex = recode(sex,
"F" = "Female",
"M" = "Male")
)
ggplot(age_sex_data,
aes(x = sex,
y = age,
fill = sex)) +
geom_boxplot(
alpha = 0.85,
outlier.alpha = 0.35,
outlier.size = 1.5
) +
scale_fill_manual(
values = c(
"Female" = "#6F4E9C",
"Male" = "#5DADE2"
)
) +
scale_y_continuous(
breaks = seq(10, 80, 10),
limits = c(10, 80)
) +
labs(
title = "Age Distribution of Arrests by Sex",
x = "Sex",
y = "Age",
caption = "Source: Massachusetts arrests data"
) +
theme_minimal() +
theme(
legend.position = "none",
panel.grid = element_blank(),
plot.title = element_text(hjust = 0.5),
plot.caption = element_text(size = 7, hjust = 1)
)
race_sex_data <- arrests |>
filter(!is.na(race), !is.na(sex)) |>
filter(sex %in% c("F", "M")) |>
filter(race != "U") |>
mutate(
sex = recode(sex,
"F" = "Female",
"M" = "Male"),
race = recode(race,
"B" = "Black",
"H" = "Hispanic",
"I" = "Native",
"J" = "M.E./Indian",
"O" = "Asian/Pacific",
"W" = "White")
) |>
count(race, sex) |>
group_by(race) |>
mutate(percent = n / sum(n)) |>
ungroup()
ggplot(race_sex_data,
aes(x = race,
y = percent,
fill = sex)) +
geom_col(color = "white") +
scale_fill_manual(
values = c(
"Female" = "#6F4E9C",
"Male" = "#5DADE2"
)
) +
scale_y_continuous(
labels = percent_format(),
breaks = seq(0, 1, 0.20)
) +
labs(
title = "Percent of Arrests by Race and Sex",
x = "Race",
y = "Percent of Arrests",
fill = "Sex",
caption = "Source: Massachusetts arrests data"
) +
theme_minimal() +
theme(
panel.grid = element_blank(),
axis.text.x = element_text(angle = 0, hjust = 0.5, size = 8),
plot.title = element_text(hjust = 0.5),
plot.caption = element_text(size = 7, hjust = 1),
plot.margin = margin(10, 10, 15, 10)
)
covid_year_data <- covid |>
