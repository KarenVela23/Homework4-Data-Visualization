### COVID-19 cases and deaths followed different yearly patterns

```{r}
covid_year_data <- covid |>
  group_by(year) |>
  summarize(
    avg_daily_cases = mean(daily_cases_mean, na.rm = TRUE),
    avg_daily_deaths = mean(daily_deaths_mean, na.rm = TRUE)
  ) |>
  filter(!is.na(year),
         avg_daily_cases > 0,
         avg_daily_deaths > 0)

ggplot(covid_year_data,
       aes(x = avg_daily_cases,
           y = avg_daily_deaths,
           color = factor(year))) +
  geom_point(
    size = 5,
    alpha = 0.9
  ) +
  geom_label(
    aes(label = year),
    nudge_y = 0.05,
    size = 3.5,
    label.size = 0.2,
    fill = "white",
    show.legend = FALSE
  ) +
  scale_color_manual(
    values = c(
      "2020" = "#6F4E9C",
      "2021" = "#D9822B",
      "2022" = "#4F6F8F",
      "2023" = "#7A9E7E",
      "2024" = "#C44E52"
    )
  ) +
  scale_y_continuous(
    breaks = seq(0, 2, 0.5),
    limits = c(0, 2)
  ) +
  scale_x_continuous(
    breaks = seq(0, 400, 50),
    limits = c(0, 380)
  ) +
  labs(
    title = "Average Daily COVID-19 Cases and Deaths by Year",
    x = "Average Daily Cases",
    y = "Average Daily Deaths",
    caption = "Source: COVID-19 daily country data"
  ) +
  theme_minimal() +
  theme(
    legend.position = "none",
    panel.grid = element_blank(),
    plot.caption = element_text(size = 7, hjust = 1),
    axis.text = element_text(size = 10),
    axis.title = element_text(size = 12),
    plot.title = element_text(size = 14)
  )
```

