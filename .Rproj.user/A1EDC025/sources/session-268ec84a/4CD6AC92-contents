### Original Radar Plot

```{r}
safe_avg <- safe_cities |>
  select(city, starts_with("d_"), starts_with("h_"), starts_with("i_"),
         starts_with("p_"), starts_with("e_")) |>
  pivot_longer(
    cols = -city,
    names_to = "variable",
    values_to = "value"
  ) |>
  mutate(
    dimension = case_when(
      str_starts(variable, "d_") ~ "DIGI",
      str_starts(variable, "h_") ~ "HEALTH",
      str_starts(variable, "i_") ~ "INFRA",
      str_starts(variable, "p_") ~ "PERS",
      str_starts(variable, "e_") ~ "ENVIR"
    ),
    dimension_full = case_when(
      dimension == "DIGI" ~ "Digital",
      dimension == "ENVIR" ~ "Environmental",
      dimension == "HEALTH" ~ "Health",
      dimension == "INFRA" ~ "Infrastructure",
      dimension == "PERS" ~ "Personal"
    ),
    type = case_when(
      str_detect(variable, "_in_") ~ "Input",
      str_detect(variable, "_out_") ~ "Output"
    )
  ) |>
  filter(type == "Input") |>
  group_by(city, type, dimension, dimension_full) |>
  summarize(
    value = mean(value, na.rm = TRUE),
    .groups = "drop"
  ) |>
  filter(city %in% c(
    "Singapore", "Tokyo", "London", "Sydney",
    "Lagos", "Caracas", "Cairo", "Mumbai"
  ))

original_radar <- ggplot(safe_avg, aes(x = dimension, y = value)) +
  geom_shape(
    aes(group = city),
    fill = "grey80",
    color = "grey55"
  ) +
  coord_polar() +
  facet_wrap(~ reorder(city, -value, median), ncol = 4) +
  scale_y_continuous(
    breaks = c(0, 50, 100),
    limits = c(0, 100)
  ) +
  labs(
    title = "Original Radar Plot",
    x = "",
    y = ""
  ) +
  theme_light() +
  theme(
    plot.title = element_text(hjust = 0.5, size = 12),
    axis.text.x = element_text(size = 5),
    axis.text.y = element_text(size = 4),
    strip.text = element_text(size = 7)
  )

original_radar
```

